# Configuration file for Synapse.
# Managed by Ansible - DO NOT EDIT MANUALLY
#
# This is a YAML file: see [1] for a quick introduction. Note in particular
# that *indentation is important*: all the elements of a list or dictionary
# should have the same indentation.
#
# [1] https://docs.ansible.com/ansible/latest/reference_appendices/YAMLSyntax.html

# server_name is set in conf.d/server_name.yaml for Debian installations

pid_file: "/var/run/matrix-synapse.pid"

# HTTP listener configuration
listeners:
  - bind_addresses:
{% for addr in matrix_bind_addresses %}
    - {{ addr }}
{% endfor %}
    port: {{ matrix_port }}
    resources:
    - compress: false
      names:
      - client
      - federation
    tls: {{ matrix_enable_tls | lower }}
    type: http
    x_forwarded: {{ matrix_use_x_forwarded | lower }}

# Database configuration
database:
{% if matrix_database_type == 'sqlite3' %}
  name: sqlite3
  args:
    database: {{ matrix_database_path }}
{% elif matrix_database_type == 'psycopg2' %}
  name: psycopg2
  args:
    user: {{ matrix_database_user }}
    password: {{ matrix_database_password }}
    database: {{ matrix_database_name }}
    host: {{ matrix_database_host }}
    port: {{ matrix_database_port }}
    cp_min: 5
    cp_max: 10
{% endif %}

# Logging configuration
log_config: "{{ matrix_log_config }}"

# Signing key
signing_key_path: "{{ matrix_signing_key }}"

# Federation
{% if matrix_enable_federation %}
trusted_key_servers:
{% for server in matrix_trusted_key_servers %}
  - server_name: "{{ server.server_name }}"
{% endfor %}
{% else %}
federation_domain_whitelist: []
{% endif %}

# Registration
enable_registration: {{ matrix_enable_registration | lower }}
{% if matrix_enable_registration_without_verification %}
enable_registration_without_verification: true
{% endif %}
{% if matrix_registration_shared_secret %}
registration_shared_secret: {{ matrix_registration_shared_secret }}
{% endif %}

# Media storage
media_store_path: "{{ matrix_media_store_path }}"
max_upload_size: "{{ matrix_max_upload_size }}"

# Public baseurl
{% if matrix_public_baseurl %}
public_baseurl: {{ matrix_public_baseurl }}
{% endif %}
