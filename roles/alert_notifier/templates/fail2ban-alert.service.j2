[Unit]
Description=Fail2ban Alert Check
Documentation=https://github.com/jackaltx/solti-ensemble
After=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/local/bin/fail2ban-alert.py
User={{ fail2ban_alert_user }}
Group={{ fail2ban_alert_group }}
StandardOutput=journal
StandardError=journal

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/fail2ban-alert
